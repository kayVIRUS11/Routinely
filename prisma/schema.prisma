generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "postgresql"
}

model User {
  id            String    @id @default(cuid())
  name          String?
  email         String    @unique
  emailVerified DateTime?
  password      String?
  image         String?
  isGuest       Boolean   @default(false)
  characterName String?
  characterLevel Int      @default(1)
  xp            Int       @default(0)
  onboardingComplete Boolean @default(false)
  createdAt     DateTime  @default(now())
  updatedAt     DateTime  @updatedAt
  
  accounts      Account[]
  sessions      Session[]
  modes         UserMode[]
  routines      Routine[]
  tasks         Task[]
  habits        Habit[]
  habitLogs     HabitLog[]
  achievements  UserAchievement[]
  pomodoroSessions PomodoroSession[]
  subjects      Subject[]
  timetableEntries TimetableEntry[]
  exams         Exam[]
  studySessions StudySession[]
  assignments   Assignment[]
  incomeEntries IncomeEntry[]
  expenseEntries ExpenseEntry[]
  budgets       Budget[]
  savingsGoals  SavingsGoal[]
  bills         Bill[]
  workoutPlans  WorkoutPlan[]
  workoutLogs   WorkoutLog[]
  bodyMetrics   BodyMetric[]
  projects      Project[]
  meetingLogs   MeetingLog[]
  personalGoals PersonalGoal[]
  journalEntries JournalEntry[]
  skillUnlocks  SkillUnlock[]
}

model Account {
  id                String  @id @default(cuid())
  userId            String
  type              String
  provider          String
  providerAccountId String
  refresh_token     String? @db.Text
  access_token      String? @db.Text
  expires_at        Int?
  token_type        String?
  scope             String?
  id_token          String? @db.Text
  session_state     String?
  user              User    @relation(fields: [userId], references: [id], onDelete: Cascade)
  @@unique([provider, providerAccountId])
}

model Session {
  id           String   @id @default(cuid())
  sessionToken String   @unique
  userId       String
  expires      DateTime
  user         User     @relation(fields: [userId], references: [id], onDelete: Cascade)
}

model VerificationToken {
  identifier String
  token      String   @unique
  expires    DateTime
  @@unique([identifier, token])
}

model UserMode {
  id        String   @id @default(cuid())
  userId    String
  modeType  String
  modeName  String
  icon      String?
  isActive  Boolean  @default(true)
  order     Int      @default(0)
  sections  Json     @default("{}")
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt
  syncedAt  DateTime?
  isDeleted Boolean  @default(false)
  user      User     @relation(fields: [userId], references: [id], onDelete: Cascade)
}

model Routine {
  id          String   @id @default(cuid())
  userId      String
  modeId      String?
  title       String
  description String?
  dayOfWeek   Int[]
  startTime   String
  endTime     String
  isActive    Boolean  @default(true)
  createdAt   DateTime @default(now())
  updatedAt   DateTime @updatedAt
  syncedAt    DateTime?
  isDeleted   Boolean  @default(false)
  user        User     @relation(fields: [userId], references: [id], onDelete: Cascade)
}

model Task {
  id          String   @id @default(cuid())
  userId      String
  modeId      String?
  title       String
  description String?
  dueDate     DateTime?
  completed   Boolean  @default(false)
  priority    String   @default("medium")
  isRecurring Boolean  @default(false)
  createdAt   DateTime @default(now())
  updatedAt   DateTime @updatedAt
  syncedAt    DateTime?
  isDeleted   Boolean  @default(false)
  user        User     @relation(fields: [userId], references: [id], onDelete: Cascade)
}

model Habit {
  id          String    @id @default(cuid())
  userId      String
  modeId      String?
  title       String
  description String?
  frequency   String    @default("daily")
  targetCount Int       @default(1)
  createdAt   DateTime  @default(now())
  updatedAt   DateTime  @updatedAt
  syncedAt    DateTime?
  isDeleted   Boolean   @default(false)
  user        User      @relation(fields: [userId], references: [id], onDelete: Cascade)
  logs        HabitLog[]
}

model HabitLog {
  id          String   @id @default(cuid())
  userId      String
  habitId     String
  loggedDate  String
  count       Int      @default(1)
  createdAt   DateTime @default(now())
  updatedAt   DateTime @updatedAt
  syncedAt    DateTime?
  isDeleted   Boolean  @default(false)
  user        User     @relation(fields: [userId], references: [id], onDelete: Cascade)
  habit       Habit    @relation(fields: [habitId], references: [id], onDelete: Cascade)
  @@unique([userId, habitId, loggedDate])
}

model Achievement {
  id          String   @id @default(cuid())
  name        String
  description String
  icon        String
  condition   Json
  isCustom    Boolean  @default(false)
  modeId      String?
  users       UserAchievement[]
}

model UserAchievement {
  id            String      @id @default(cuid())
  userId        String
  achievementId String
  earnedAt      DateTime    @default(now())
  xp            Int         @default(0)
  syncedAt      DateTime?
  isDeleted     Boolean     @default(false)
  user          User        @relation(fields: [userId], references: [id], onDelete: Cascade)
  achievement   Achievement @relation(fields: [achievementId], references: [id], onDelete: Cascade)
  @@unique([userId, achievementId])
}

model PomodoroSession {
  id            String   @id @default(cuid())
  userId        String
  modeId        String?
  taskName      String   @default("")
  durationMinutes Int    @default(25)
  completed     Boolean  @default(true)
  startedAt     DateTime @default(now())
  endedAt       DateTime?
  createdAt     DateTime @default(now())
  updatedAt     DateTime @updatedAt
  syncedAt      DateTime?
  isDeleted     Boolean  @default(false)
  user          User     @relation(fields: [userId], references: [id], onDelete: Cascade)
}

// ─── Study mode ───────────────────────────────────────────────────────────────

model Subject {
  id        String   @id @default(cuid())
  userId    String
  name      String
  color     String?
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt
  syncedAt  DateTime?
  isDeleted Boolean  @default(false)
  user      User     @relation(fields: [userId], references: [id], onDelete: Cascade)
  timetable TimetableEntry[]
  exams     Exam[]
  studySessions StudySession[]
  assignments Assignment[]
}

model TimetableEntry {
  id          String   @id @default(cuid())
  userId      String
  subjectId   String
  dayOfWeek   Int
  startTime   String
  endTime     String
  location    String?
  createdAt   DateTime @default(now())
  updatedAt   DateTime @updatedAt
  syncedAt    DateTime?
  isDeleted   Boolean  @default(false)
  user        User     @relation(fields: [userId], references: [id], onDelete: Cascade)
  subject     Subject  @relation(fields: [subjectId], references: [id], onDelete: Cascade)
}

model Exam {
  id         String   @id @default(cuid())
  userId     String
  subjectId  String
  title      String
  examDate   String
  notes      String?
  createdAt  DateTime @default(now())
  updatedAt  DateTime @updatedAt
  syncedAt   DateTime?
  isDeleted  Boolean  @default(false)
  user       User     @relation(fields: [userId], references: [id], onDelete: Cascade)
  subject    Subject  @relation(fields: [subjectId], references: [id], onDelete: Cascade)
}

model StudySession {
  id              String   @id @default(cuid())
  userId          String
  subjectId       String?
  taskName        String?
  durationMinutes Int
  sessionDate     String
  createdAt       DateTime @default(now())
  updatedAt       DateTime @updatedAt
  syncedAt        DateTime?
  isDeleted       Boolean  @default(false)
  user            User     @relation(fields: [userId], references: [id], onDelete: Cascade)
  subject         Subject? @relation(fields: [subjectId], references: [id], onDelete: SetNull)
}

model Assignment {
  id          String   @id @default(cuid())
  userId      String
  subjectId   String?
  title       String
  dueDate     String?
  completed   Boolean  @default(false)
  priority    String   @default("medium")
  createdAt   DateTime @default(now())
  updatedAt   DateTime @updatedAt
  syncedAt    DateTime?
  isDeleted   Boolean  @default(false)
  user        User     @relation(fields: [userId], references: [id], onDelete: Cascade)
  subject     Subject? @relation(fields: [subjectId], references: [id], onDelete: SetNull)
}

// ─── Financial mode ───────────────────────────────────────────────────────────

model IncomeEntry {
  id        String   @id @default(cuid())
  userId    String
  title     String
  amount    Float
  date      String
  category  String?
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt
  syncedAt  DateTime?
  isDeleted Boolean  @default(false)
  user      User     @relation(fields: [userId], references: [id], onDelete: Cascade)
}

model ExpenseEntry {
  id        String   @id @default(cuid())
  userId    String
  title     String
  amount    Float
  date      String
  category  String?
  budgetId  String?
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt
  syncedAt  DateTime?
  isDeleted Boolean  @default(false)
  user      User     @relation(fields: [userId], references: [id], onDelete: Cascade)
}

model Budget {
  id          String   @id @default(cuid())
  userId      String
  category    String
  limitAmount Float
  period      String   @default("monthly")
  createdAt   DateTime @default(now())
  updatedAt   DateTime @updatedAt
  syncedAt    DateTime?
  isDeleted   Boolean  @default(false)
  user        User     @relation(fields: [userId], references: [id], onDelete: Cascade)
}

model SavingsGoal {
  id            String   @id @default(cuid())
  userId        String
  title         String
  targetAmount  Float
  currentAmount Float    @default(0)
  targetDate    String?
  createdAt     DateTime @default(now())
  updatedAt     DateTime @updatedAt
  syncedAt      DateTime?
  isDeleted     Boolean  @default(false)
  user          User     @relation(fields: [userId], references: [id], onDelete: Cascade)
}

model Bill {
  id        String   @id @default(cuid())
  userId    String
  title     String
  amount    Float
  dueDate   String
  isPaid    Boolean  @default(false)
  recurring Boolean  @default(false)
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt
  syncedAt  DateTime?
  isDeleted Boolean  @default(false)
  user      User     @relation(fields: [userId], references: [id], onDelete: Cascade)
}

// ─── Fitness mode ─────────────────────────────────────────────────────────────

model WorkoutPlan {
  id            String   @id @default(cuid())
  userId        String
  title         String
  scheduledDate String?
  dayOfWeek     Int?
  exercises     Json     @default("[]")
  createdAt     DateTime @default(now())
  updatedAt     DateTime @updatedAt
  syncedAt      DateTime?
  isDeleted     Boolean  @default(false)
  user          User     @relation(fields: [userId], references: [id], onDelete: Cascade)
  logs          WorkoutLog[]
}

model WorkoutLog {
  id              String   @id @default(cuid())
  userId          String
  planId          String?
  title           String
  logDate         String
  durationMinutes Int?
  notes           String?
  createdAt       DateTime @default(now())
  updatedAt       DateTime @updatedAt
  syncedAt        DateTime?
  isDeleted       Boolean  @default(false)
  user            User     @relation(fields: [userId], references: [id], onDelete: Cascade)
  plan            WorkoutPlan? @relation(fields: [planId], references: [id], onDelete: SetNull)
}

model BodyMetric {
  id           String   @id @default(cuid())
  userId       String
  metricType   String
  value        Float
  unit         String
  recordedDate String
  createdAt    DateTime @default(now())
  updatedAt    DateTime @updatedAt
  syncedAt     DateTime?
  isDeleted    Boolean  @default(false)
  user         User     @relation(fields: [userId], references: [id], onDelete: Cascade)
}

// ─── Professional mode ────────────────────────────────────────────────────────

model Project {
  id          String   @id @default(cuid())
  userId      String
  title       String
  description String?
  status      String   @default("active")
  deadline    String?
  createdAt   DateTime @default(now())
  updatedAt   DateTime @updatedAt
  syncedAt    DateTime?
  isDeleted   Boolean  @default(false)
  user        User     @relation(fields: [userId], references: [id], onDelete: Cascade)
  meetings    MeetingLog[]
}

model MeetingLog {
  id          String   @id @default(cuid())
  userId      String
  projectId   String?
  title       String
  meetingDate String
  notes       String?
  createdAt   DateTime @default(now())
  updatedAt   DateTime @updatedAt
  syncedAt    DateTime?
  isDeleted   Boolean  @default(false)
  user        User     @relation(fields: [userId], references: [id], onDelete: Cascade)
  project     Project? @relation(fields: [projectId], references: [id], onDelete: SetNull)
}

// ─── General mode ─────────────────────────────────────────────────────────────

model PersonalGoal {
  id          String   @id @default(cuid())
  userId      String
  title       String
  description String?
  targetDate  String?
  completed   Boolean  @default(false)
  createdAt   DateTime @default(now())
  updatedAt   DateTime @updatedAt
  syncedAt    DateTime?
  isDeleted   Boolean  @default(false)
  user        User     @relation(fields: [userId], references: [id], onDelete: Cascade)
}

model JournalEntry {
  id         String   @id @default(cuid())
  userId     String
  title      String?
  body       String   @db.Text
  entryDate  String
  mood       String?
  createdAt  DateTime @default(now())
  updatedAt  DateTime @updatedAt
  syncedAt   DateTime?
  isDeleted  Boolean  @default(false)
  user       User     @relation(fields: [userId], references: [id], onDelete: Cascade)
}

// ─── RPG / gamification ───────────────────────────────────────────────────────

model SkillUnlock {
  id          String   @id @default(cuid())
  userId      String
  skillName   String
  modeId      String?
  level       Int      @default(1)
  unlockedAt  DateTime @default(now())
  createdAt   DateTime @default(now())
  updatedAt   DateTime @updatedAt
  syncedAt    DateTime?
  isDeleted   Boolean  @default(false)
  user        User     @relation(fields: [userId], references: [id], onDelete: Cascade)
}

